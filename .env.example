# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security
JWT_SECRET=change-me-to-a-long-random-string-in-production
ROOM_TOKEN_SECRET=change-me-room-token-secret
SESSION_EXPIRY_HOURS=24

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Streaming
STREAM_CHUNK_TIMEOUT_MS=30000
MAX_CONCURRENT_STREAM_REQUESTS=50

# Redis (future-ready, optional)
REDIS_URL=

# Client (Vite)
# Local dev: leave empty to use Vite proxy on :5173
# Vercel production: set to your deployed backend URL (Railway, Render, Fly.io, VPS)
# Note: Socket.IO + streaming require a persistent server — NOT Vercel serverless
VITE_API_URL=
VITE_WS_URL=

# Example production:
# VITE_API_URL=https://your-api.railway.app
# VITE_WS_URL=https://your-api.railway.app
