# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Security
JWT_SECRET=change-me-to-a-long-random-string-in-production
ROOM_TOKEN_SECRET=change-me-room-token-secret
SESSION_EXPIRY_HOURS=24

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Streaming
STREAM_CHUNK_TIMEOUT_MS=30000
MAX_CONCURRENT_STREAM_REQUESTS=50

# Redis (required on Vercel — rooms are stored here across serverless instances)
# Create free database: https://vercel.com/marketplace/upstash
# Or: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV uses the same REST API shape (auto-set when using Vercel KV integration)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Legacy alias (optional)
REDIS_URL=

# Client (Next.js)
# Local dev with custom server: leave empty — same-origin /api and /socket.io on :3000
# Vercel frontend-only deploy: set to your backend URL (Railway, Render, Fly.io, VPS)
# Note: Socket.IO + streaming require a persistent server — NOT Vercel serverless
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# Example production (Vercel frontend + external backend):
# NEXT_PUBLIC_API_URL=https://your-api.railway.app
# NEXT_PUBLIC_WS_URL=https://your-api.railway.app
